# Backend runtime configuration.
PORT=3001

# Polygon Amoy RPC endpoint — use the same provider you used for contract deployment
RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_API_KEY

# Issuer wallet private key (0x-prefixed 32-byte hex, same as contracts/.env PRIVATE_KEY)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# AcademicCertification deployed address on Polygon Amoy
CONTRACT_ADDRESS=0xE1611Dfd95143443434343434343333Cc30CE553

# Polygon Amoy chain ID
CHAIN_ID=80002

# Public frontend URL used to build certificate verification links
# Use http://localhost:3000 for local MVP demos with npm run dev
FRONTEND_BASE_URL=http://localhost:3000

# MongoDB connection for off-chain certificate persistence
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DATABASE_NAME=tfm_certificacion_blockchain

# Pinata IPFS credentials (use ONE mode)
# Mode A: JWT (recommended)
PINATA_JWT=

# Mode B: API Key + Secret
PINATA_API_KEY=
PINATA_API_SECRET=

# Optional custom Pinata API URL
PINATA_BASE_URL=https://api.pinata.cloud

# JWT settings for SIWE login sessions
JWT_SECRET=change-this-dev-secret
JWT_ISSUER=tfm-certificacion-backend
JWT_AUDIENCE=tfm-certificacion-frontend
JWT_EXPIRES_IN=2h
SIWE_NONCE_TTL_SECONDS=300
