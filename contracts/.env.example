# Polygon Amoy deployment environment
# Fill ONLY one signer option: PRIVATE_KEY OR MNEMONIC

# Option A (recommended): wallet private key with AMOY test MATIC for gas
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Option B: 12/24 word seed phrase (do not commit real secrets)
MNEMONIC=

# Polygon Amoy RPC endpoint (Alchemy / Infura / QuickNode / Chainstack / Ankr)
RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_API_KEY

# Optional, for future contract verification in explorers
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY
